    """
    m, n = len(text1), len(text2)
    dp = [[0] * (n + 1) for _ in range(m + 1)]
    for i in range(m):
        for j in range(n):
            dp[i][j] = max(dp[i][j], dp[i][j + 1])
    return dp[m][n]

