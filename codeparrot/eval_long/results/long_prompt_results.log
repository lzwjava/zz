<|bos|>def is_prime(n: int) -> bool:
    """Check if a number is prime."""
    if n < 2:
        return False
    for i in range(2, int(n ** 0.5) + 1):
        if n % i == 0:
            return False
    return True


def prime_factors(n: int) -> list:
    """Return the prime factors of a number as a list."""
    factors = []
    divisor = 2
    while n > 1:  # n is a number
        if n % divisor == 0:
            divisor += 1
        else:
            factors.append(n // divisor)
            n = n % divisor
    return factors


def is_prime_factors(n: int) -> bool:
    """Check if a number is prime factors of a number."""
    factors = prime_factors(n)
    for factor in factors:
        if is_prime(factor):
            return True
    return False


def prime_factors(n: int) -> list:
    """Return the prime factors of a number as a list."""
    factors = prime_factors(n)
    factors = [int(x) for x in factors]
    for i in range(2, int(n ** 0.5) + 1):
        if n % i == 0:
            factors.append(i)
    return factors


