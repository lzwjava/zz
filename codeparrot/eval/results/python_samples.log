<|bos|>class Stack: # A stack is a list of elements, which can be added to a stack.
    def __init__(self):
        self._stack = []
        self._stack.append(None)

    def push(self, item):
        self._stack.append(item)

    def pop(self):
        return self._stack.pop()

    def peek(self):
        return self._stack[-1]

    def is_empty(self):
        return len(self._stack) == 0

